# ---- Banco de dados ----
# URL de runtime. Em serverless (Neon/Supabase), use a connection string COM pooler.
DATABASE_URL="postgresql://financenan:financenan@localhost:5432/financenan?schema=public"
# Conexão DIRETA (sem pooler), usada por `prisma migrate`. Em dev pode ser igual à DATABASE_URL.
DIRECT_URL="postgresql://financenan:financenan@localhost:5432/financenan?schema=public"

# ---- Servidor ----
PORT=3333
HOST=0.0.0.0
NODE_ENV=development

# ---- JWT (use strings longas e aleatórias em produção) ----
JWT_ACCESS_SECRET="change-me-access-secret-please"
JWT_REFRESH_SECRET="change-me-refresh-secret-please"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="30d"

# ---- CORS (origens separadas por vírgula, ou * para todas) ----
CORS_ORIGIN="*"
